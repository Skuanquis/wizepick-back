# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here
DATABASE_NAME=wizepick_db
# Set to false in production - use migrations instead
DATABASE_SYNCHRONIZE=false
# Enable SQL logging in development
DATABASE_LOGGING=true

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-very-long-random-secret-min-32-chars
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-secret
JWT_REFRESH_EXPIRATION=7d

# ============================================
# APPLICATION CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
API_PREFIX=api
API_VERSION=v1

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4200,http://localhost:3001

# ============================================
# RATE LIMITING
# ============================================
# Time to live in seconds
THROTTLE_TTL=60
# Maximum number of requests within TTL
THROTTLE_LIMIT=100

# ============================================
# BCRYPT CONFIGURATION
# ============================================
# Salt rounds for password hashing (10-12 recommended)
BCRYPT_SALT_ROUNDS=10

# ============================================
# FILE UPLOAD (Optional)
# ============================================
MAX_FILE_SIZE=5242880
# 5MB in bytes
UPLOAD_DIR=./uploads

# ============================================
# SWAGGER DOCUMENTATION
# ============================================
SWAGGER_ENABLED=true
SWAGGER_TITLE=WizePick API
SWAGGER_DESCRIPTION=Sistema de Control de Inventarios Multi-Negocio
SWAGGER_VERSION=2.0
SWAGGER_PREFIX=api/docs

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
# Options: error, warn, info, debug, verbose

# ============================================
# REDIS (Optional - for caching)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@wizepick.com

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=http://localhost:4200

# ============================================
# TIMEZONE
# ============================================
TZ=America/Bogota
